---
/**
 * Now Page - Spanish - What I'm currently doing
 */
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Header from "../../../components/Header.astro";

const lang = "es";
const lastUpdated = "Febrero 2026";
---

<BaseLayout 
  title="Ahora | Juan Narvaez"
  description="En qué estoy trabajando, aprendiendo y enfocado actualmente."
  lang={lang}
>
  <Header />

  <main id="main-content" class="container">
    <div class="page-header">
      <h1 class="page-title">Qué estoy haciendo ahora</h1>
      <p class="last-updated">Última actualización: {lastUpdated}</p>
    </div>

    <div class="content">
      <!-- Working On -->
      <section class="section">
        <h2 class="section-title">🛠️ Trabajando en</h2>
        <ul class="list">
          <li>
            <strong>Gastiflow v2.0</strong> — Ecosistema de finanzas personales con 
            integración de Telegram y análisis con IA. Reescribiendo el backend con 
            mejor arquitectura y agregando nuevas funcionalidades.
          </li>
          <li>
            <strong>Este portfolio</strong> — Mejorando continuamente el diseño, 
            agregando nuevas funciones y escribiendo posts sobre lo que aprendo.
          </li>
          <li>
            <strong>Contribuciones open source</strong> — Manteniendo mis proyectos 
            de template de Telegram bot y FastAPI starter.
          </li>
        </ul>
      </section>

      <!-- Learning -->
      <section class="section">
        <h2 class="section-title">📚 Aprendiendo</h2>
        <ul class="list">
          <li>
            <strong>System Design</strong> — Leyendo "Designing Data-Intensive Applications" 
            y aprendiendo sobre patrones de sistemas distribuidos.
          </li>
          <li>
            <strong>Rust</strong> — Explorando Rust para servicios backend de alto rendimiento. 
            Construyendo pequeñas herramientas CLI para familiarizarme con el lenguaje.
          </li>
          <li>
            <strong>Inglés</strong> — Mejorando mi inglés técnico para escribir mejor 
            documentación y posts.
          </li>
        </ul>
      </section>

      <!-- Current Focus -->
      <section class="section">
        <h2 class="section-title">🎯 Enfoque actual</h2>
        <ul class="list">
          <li>Construir arquitecturas backend escalables y mantenibles</li>
          <li>Escribir código limpio y bien documentado</li>
          <li>Contribuir a proyectos open source</li>
          <li>Compartir conocimiento a través de posts</li>
        </ul>
      </section>

      <!-- Reading -->
      <section class="section">
        <h2 class="section-title">📖 Leyendo</h2>
        <ul class="list">
          <li>"Designing Data-Intensive Applications" de Martin Kleppmann</li>
          <li>"Clean Architecture" de Robert C. Martin</li>
        </ul>
      </section>

      <!-- Location -->
      <section class="section">
        <h2 class="section-title">📍 Ubicación</h2>
        <p class="text">
          Buenos Aires, Argentina. Abierto a oportunidades remotas en todo el mundo.
        </p>
      </section>

      <!-- Inspiration -->
      <div class="inspiration">
        <p>
          <a href="https://nownownow.com/about" target="_blank" rel="noopener noreferrer" class="link">
            ¿Qué es una página "ahora"?
          </a>
        </p>
      </div>
    </div>
  </main>
</BaseLayout>

<style>
  .page-header {
    padding: 3rem 0 2rem;
    border-bottom: 1px solid var(--border-color);
    margin-bottom: 2rem;
  }

  .page-title {
    font-size: 1.75rem;
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: 0.5rem;
  }

  .last-updated {
    font-size: 0.875rem;
    color: var(--text-muted);
    margin: 0;
  }

  .content {
    padding-bottom: 4rem;
  }

  .section {
    margin-bottom: 2.5rem;
  }

  .section-title {
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: 1rem;
  }

  .list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.875rem;
  }

  .list li {
    font-size: 0.9375rem;
    line-height: 1.7;
    color: var(--text-secondary);
    padding-left: 1.25rem;
    position: relative;
  }

  .list li::before {
    content: "•";
    position: absolute;
    left: 0;
    color: var(--text-muted);
  }

  .list li strong {
    color: var(--text-primary);
    font-weight: 600;
  }

  .text {
    font-size: 0.9375rem;
    line-height: 1.7;
    color: var(--text-secondary);
    margin: 0;
  }

  .inspiration {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid var(--border-color);
  }

  .inspiration p {
    font-size: 0.875rem;
    color: var(--text-muted);
    margin: 0;
  }

  .link {
    color: var(--text-muted);
    text-decoration: underline;
    text-underline-offset: 2px;
    transition: color 150ms ease;
  }

  .link:hover {
    color: var(--text-primary);
  }

  @media (max-width: 640px) {
    .page-header {
      padding: 2rem 0 1.5rem;
    }

    .page-title {
      font-size: 1.5rem;
    }
  }
</style>
