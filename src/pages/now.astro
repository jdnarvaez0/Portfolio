---
/**
 * Now Page - Simplified version
 */
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";

const lang = "en";
const lastUpdated = "February 2026";
---

<BaseLayout 
  title="Now | Juan Narvaez"
  description="What I'm currently working on."
  lang={lang}
>
  <Header />

  <main id="main-content" class="container">
    <div class="page-header">
      <h1 class="page-title">What I'm doing now</h1>
      <p class="last-updated">Last updated: {lastUpdated}</p>
    </div>

    <div class="content">
      <!-- Working On -->
      <section class="section">
        <h2 class="section-title">🛠️ Working on</h2>
        <ul class="list">
          <li>
            <strong>Gastiflow</strong> — Personal finance app with Telegram integration
          </li>
          <li>
            <strong>This portfolio</strong> — Writing blog posts and improving the design
          </li>
          <li>
            <strong>Open source</strong> — Maintaining my Telegram bot and FastAPI templates
          </li>
        </ul>
      </section>

      <!-- Location -->
      <section class="section">
        <h2 class="section-title">📍 Location</h2>
        <p class="text">
          Buenos Aires, Argentina. Open to remote opportunities.
        </p>
      </section>

      <!-- Inspiration -->
      <div class="inspiration">
        <p>
          <a href="https://nownownow.com/about" target="_blank" rel="noopener noreferrer" class="link">
            What is a "now" page?
          </a>
        </p>
      </div>
    </div>
  </main>
</BaseLayout>

<style>
  .page-header {
    padding: 3rem 0 2rem;
    border-bottom: 1px solid var(--border-color);
    margin-bottom: 2rem;
  }

  .page-title {
    font-size: 1.75rem;
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: 0.5rem;
  }

  .last-updated {
    font-size: 0.875rem;
    color: var(--text-muted);
    margin: 0;
  }

  .content {
    padding-bottom: 4rem;
  }

  .section {
    margin-bottom: 2rem;
  }

  .section-title {
    font-size: 1rem;
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: 0.75rem;
  }

  .list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .list li {
    font-size: 0.9375rem;
    line-height: 1.6;
    color: var(--text-secondary);
    padding-left: 1rem;
    position: relative;
  }

  .list li::before {
    content: "•";
    position: absolute;
    left: 0;
    color: var(--text-muted);
  }

  .list li strong {
    color: var(--text-primary);
    font-weight: 600;
  }

  .text {
    font-size: 0.9375rem;
    line-height: 1.6;
    color: var(--text-secondary);
    margin: 0;
  }

  .inspiration {
    margin-top: 2rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border-color);
  }

  .inspiration p {
    font-size: 0.8125rem;
    color: var(--text-muted);
    margin: 0;
  }

  .link {
    color: var(--text-muted);
    text-decoration: underline;
    text-underline-offset: 2px;
    transition: color 150ms ease;
  }

  .link:hover {
    color: var(--text-primary);
  }

  @media (max-width: 640px) {
    .page-header {
      padding: 2rem 0 1.5rem;
    }

    .page-title {
      font-size: 1.5rem;
    }
  }
</style>
