---
/**
 * Hero - Simple y limpio como pheralb.dev
 */
import { getLangFromUrl, t } from "../i18n/translations";

const lang = getLangFromUrl(Astro.url);

const description = t(lang, "hero.description");
---

<section class="hero">
  <p class="hero-text">
    {description}
  </p>
</section>

<style>
  .hero {
    padding: 3rem 0 2rem;
    margin-bottom: 2rem;
  }

  .hero-text {
    font-size: 1.125rem;
    line-height: 1.8;
    color: var(--text-secondary);
    max-width: 600px;
  }

  @media (max-width: 640px) {
    .hero {
      padding: 2rem 0 1.5rem;
    }
    
    .hero-text {
      font-size: 1rem;
      line-height: 1.7;
    }
  }
</style>
